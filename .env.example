# HELIOS VIEW — Environment Variables
# Copy to .env.local and fill in values

# HELIOS Protocol API Endpoints
NEXT_PUBLIC_ATLAS_WS_URL=wss://atlas.helios.network/stream
NEXT_PUBLIC_VULCAN_API_URL=https://vulcan.helios.network/api
NEXT_PUBLIC_ARCHON_WS_URL=wss://archon.helios.network/status
NEXT_PUBLIC_SNP_API_URL=https://snp.helios.network/api

# Blockchain
NEXT_PUBLIC_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_HELIOS_CONTRACT=0x...
NEXT_PUBLIC_CODEX_CONTRACT=0x...

# Auth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://view.helios.network

# WebGPU / 3D
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Feature Flags
NEXT_PUBLIC_GOD_MODE_ENABLED=true
NEXT_PUBLIC_BIOMETRIC_AUTH_ENABLED=true
